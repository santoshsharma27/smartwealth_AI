# =============================================================================
# SmartWealth AI Service - Environment Variables
# =============================================================================
# Copy this file to .env and configure your preferred LLM provider.
# The AI service works with ANY OpenAI-compatible API.
# =============================================================================

# --- LLM Provider Configuration ---
# Choose your provider by setting LLM_PROVIDER and the corresponding vars.
# Supported: openai, azure, anthropic, google, groq, together, ollama, lmstudio, custom
LLM_PROVIDER=lmstudio

# --- Provider: OpenAI ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o-mini

# --- Provider: Azure OpenAI ---
# LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/
# LLM_API_KEY=your-azure-key
# LLM_MODEL=gpt-4o-mini

# --- Provider: Anthropic (via OpenAI-compatible proxy) ---
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_API_KEY=sk-ant-your-key
# LLM_MODEL=claude-3-5-sonnet-20241022

# --- Provider: Google Gemini (via OpenAI-compatible endpoint) ---
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY=your-google-api-key
# LLM_MODEL=gemini-2.0-flash

# --- Provider: Groq ---
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your-groq-key
# LLM_MODEL=llama-3.1-70b-versatile

# --- Provider: Together AI ---
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=your-together-key
# LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# --- Provider: Ollama (local) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

# --- Provider: LM Studio (local, default) ---
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=

# --- Provider: Custom OpenAI-compatible endpoint ---
# LLM_BASE_URL=http://your-server:port/v1
# LLM_API_KEY=your-key
# LLM_MODEL=your-model

# --- Common LLM Settings ---
LLM_ENABLED=true
LLM_TIMEOUT=30
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3

# --- Legacy (still works, maps to LLM_API_KEY) ---
# OPENAI_API_KEY=sk-your-key

# --- Database ---
DATABASE_URL=postgresql://smartwealth:smartwealth_dev@localhost:5432/smartwealth
