# =============================================================================
# SmartWealth AI - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# NOTE: Default values are provided for local development. You only need to
# override values that differ from the defaults.
# =============================================================================

# --- PostgreSQL Database ---
POSTGRES_DB=smartwealth
POSTGRES_USER=smartwealth
POSTGRES_PASSWORD=smartwealth_dev

# --- Quarkus Backend ---
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://postgres:5432/smartwealth
QUARKUS_DATASOURCE_USERNAME=smartwealth
QUARKUS_DATASOURCE_PASSWORD=smartwealth_dev
AI_SERVICE_BASE_URL=http://ai-service:8000

# --- AI Service (FastAPI) ---
DATABASE_URL=postgresql://smartwealth:smartwealth_dev@postgres:5432/smartwealth
AI_SERVICE_DEBUG=false

# --- LLM Provider Configuration ---
# Set LLM_PROVIDER to switch between providers. All use OpenAI-compatible API.
# Supported: openai, azure, anthropic, google, groq, together, ollama, lmstudio, custom
#
# Examples:
#   OpenAI:    LLM_PROVIDER=openai    LLM_API_KEY=sk-...
#   Gemini:    LLM_PROVIDER=google    LLM_API_KEY=your-google-key
#   Groq:      LLM_PROVIDER=groq      LLM_API_KEY=gsk_...
#   Together:  LLM_PROVIDER=together   LLM_API_KEY=your-together-key
#   Anthropic: LLM_PROVIDER=anthropic  LLM_API_KEY=sk-ant-...
#   Ollama:    LLM_PROVIDER=ollama    (no key needed, local)
#   LM Studio: LLM_PROVIDER=lmstudio  (no key needed, local)
#   Custom:    LLM_BASE_URL=http://your-server/v1  LLM_API_KEY=your-key
#
LLM_PROVIDER=lmstudio
LLM_API_KEY=lm-studio
# LLM_BASE_URL=                  (auto-set by provider, override for custom)
# LLM_MODEL=                     (auto-set by provider, override if needed)
LLM_ENABLED=true
LLM_TIMEOUT=30
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3

# Legacy (still supported, maps to LLM_API_KEY)
# OPENAI_API_KEY=sk-your-key

# --- Frontend (run locally with `npm run dev`, not in Docker) ---
# Set this in frontend/.env or frontend/.env.local
# VITE_API_BASE_URL=http://localhost:8080
